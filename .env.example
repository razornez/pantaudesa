# NextAuth
AUTH_SECRET=
AUTH_URL=

# Database (Supabase / PostgreSQL)
# DATABASE_URL is the runtime connection used by next dev, API routes, and local app reads/writes.
# Recommended for Supabase local runtime: transaction pooler URL, usually port 6543 with pgbouncer=true.
DATABASE_URL=

# DIRECT_URL is migration/admin-only. Do not use it for local runtime unless explicitly debugging.
# Supabase direct DB host can be IPv6-only; session pooler/direct paths may fail on some local networks.
DIRECT_URL=

# Optional local debug override. Keep false by default so runtime uses DATABASE_URL.
PANTAUDESA_LOCAL_DB_USE_DIRECT_URL=false

# Optional local Next dev pool tuning for Supabase pooler DATABASE_URL.
# The app raises too-small local pooler URLs to these values at runtime to prevent Prisma P2024 starvation.
PANTAUDESA_LOCAL_DB_CONNECTION_LIMIT=5
PANTAUDESA_LOCAL_DB_POOL_TIMEOUT=20

# Optional template sync override. Set only when template sync must use a different stable admin URL.
TEMPLATE_SYNC_DATABASE_URL=
TEMPLATE_SYNC_USE_DIRECT_URL=false
TEMPLATE_SYNC_STAGE_TIMEOUT_MS=120000

# Resend (email)
RESEND_API_KEY=
RESEND_FROM=

# Sentry
SENTRY_DSN=

# Alert
ALERT_EMAIL=

# Contact admin (used by /api/admin-claim/contact-admin and Pengajuan Admin Desa)
# Set to the internal email that receives user support requests (e.g. cs@razornez.net)
CONTACT_EMAIL=

# ── Supabase Storage (Admin Desa documents) ────────────────────────────────────
# REQUIRED to enable document upload, preview, and delete.
# Both vars must be set; if either is missing, storage is disabled (returns 503).
#
# NEXT_PUBLIC_SUPABASE_URL  — project URL from Supabase dashboard → Settings → API
#   Format: https://<project-ref>.supabase.co
#   Safe to expose in browser (no secret).
#
# SUPABASE_SERVICE_ROLE_KEY — service_role key from Supabase dashboard → Settings → API
#   SERVER-ONLY — never expose to the browser or commit to git.
#   Used server-side only (upload, signed URL, delete).
#
# Bucket: create a PRIVATE bucket named "admin-desa-documents" in Supabase Storage.
#   No public access; all reads go through signed URLs (TTL: SUPABASE_STORAGE_SIGNED_URL_TTL_SECONDS).
#   Owner manual action: create bucket before first upload, or storage will return 404/403.
#
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Supabase Storage — optional tuning ────────────────────────────────────────
# SUPABASE_STORAGE_BUCKET_ADMIN_DESA_DOCUMENTS  — bucket name (default: admin-desa-documents)
# SUPABASE_STORAGE_SIGNED_URL_TTL_SECONDS       — signed URL lifetime in seconds (default: 900 = 15 min)
# ADMIN_DESA_DOCUMENT_MAX_FILE_SIZE_MB          — per-file size limit in MB (default: 10)
# ADMIN_DESA_DOCUMENT_MAX_FILES_PER_UPLOAD      — max files per single upload request (default: 5)
# ADMIN_DESA_DOCUMENT_ALLOWED_MIME_TYPES        — comma-separated MIME types (default: application/pdf,image/jpeg,image/png,image/webp)
#
SUPABASE_STORAGE_BUCKET_ADMIN_DESA_DOCUMENTS=admin-desa-documents
SUPABASE_STORAGE_BUCKET_PROFILE_PHOTOS=user-profile-photos
SUPABASE_STORAGE_SIGNED_URL_TTL_SECONDS=900
ADMIN_DESA_DOCUMENT_MAX_FILE_SIZE_MB=10
ADMIN_DESA_DOCUMENT_MAX_FILES_PER_UPLOAD=5
ADMIN_DESA_DOCUMENT_ALLOWED_MIME_TYPES=application/pdf,image/jpeg,image/png,image/webp

# ── Geocoding (LocationIQ) ─────────────────────────────────────────────────────
# OPTIONAL — only needed to run the desa coordinate geocoding sweep
# (scripts/ingest-run.ts --only locationiq) and the nightly GitHub Action.
# Register free at https://locationiq.com/ (~5,000 req/day). Works from cloud
# IPs, unlike the public Nominatim endpoint. Not needed to run the app itself.
LOCATIONIQ_KEY=

# ── Base URL ───────────────────────────────────────────────────────────────────
# Used by sitemap, robots.txt, and OG image metadata.
# Set to your production URL (custom domain or Vercel URL).
# Example: https://pantaudesa.id  OR  https://pantaudesa.vercel.app
NEXT_PUBLIC_BASE_URL=https://pantaudesa.vercel.app

# Debug (dev only, jangan set di production)
DEBUG_SECRET=
