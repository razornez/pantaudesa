generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  // NextAuth required fields — must match exact names PrismaAdapter expects
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  // PantauDesa custom fields
  username       String?   @unique
  nama           String?
  bio            String?
  avatarUrl      String?
  role           Role      @default(WARGA)
  // PIN auth
  pinHash        String?
  pinAttempts    Int       @default(0)
  pinLockedUntil DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // NextAuth relations
  accounts Account[]
  sessions Session[]

  // Citizen voice relations
  voices     Voice[]
  replies    VoiceReply[]
  votes      VoiceVote[]
  helpfuls   VoiceHelpful[]

  @@map("users")
}

// ─── OTP ──────────────────────────────────────────────────────────────────────

model OtpCode {
  id        String     @id @default(cuid())
  email     String
  codeHash  String
  purpose   OtpPurpose
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime   @default(now())

  @@index([email, purpose])
  @@map("otp_codes")
}

enum OtpPurpose {
  REGISTER
  RESET_PIN
  UNFREEZE
}

// ─── Citizen Voice ────────────────────────────────────────────────────────────

model Voice {
  id         String        @id @default(cuid())
  desaId     String
  category   VoiceCategory
  text       String        @db.Text
  isAnon     Boolean       @default(false)
  status     VoiceStatus   @default(OPEN)
  resolvedAt DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  authorId   String?
  author     User?         @relation(fields: [authorId], references: [id], onDelete: SetNull)

  replies    VoiceReply[]
  votes      VoiceVote[]
  helpfuls   VoiceHelpful[]

  @@index([desaId])
  @@index([createdAt])
  @@map("voices")
}

model VoiceReply {
  id              String   @id @default(cuid())
  voiceId         String
  text            String   @db.Text
  isAnon          Boolean  @default(false)
  isOfficialDesa  Boolean  @default(false)
  createdAt       DateTime @default(now())

  authorId  String?
  author    User?   @relation(fields: [authorId], references: [id], onDelete: SetNull)
  voice     Voice   @relation(fields: [voiceId], references: [id], onDelete: Cascade)

  @@index([voiceId])
  @@map("voice_replies")
}

model VoiceVote {
  id        String    @id @default(cuid())
  voiceId   String
  userId    String
  type      VoteType
  createdAt DateTime  @default(now())

  voice  Voice @relation(fields: [voiceId], references: [id], onDelete: Cascade)
  user   User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([voiceId, userId])
  @@map("voice_votes")
}

model VoiceHelpful {
  id        String   @id @default(cuid())
  voiceId   String
  userId    String
  createdAt DateTime @default(now())

  voice  Voice @relation(fields: [voiceId], references: [id], onDelete: Cascade)
  user   User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([voiceId, userId])
  @@map("voice_helpfuls")
}

enum VoiceCategory {
  infrastruktur
  bansos
  fasilitas
  anggaran
  lingkungan
  lainnya
}

enum VoiceStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum VoteType {
  BENAR
  BOHONG
}

enum Role {
  WARGA
  DESA
  ADMIN
}

// Data Desa Foundation

model Desa {
  id             String     @id @default(cuid())
  kodeDesa       String?    @unique
  nama           String
  slug           String     @unique
  kecamatan      String
  kabupaten      String
  provinsi       String
  tahunData      Int
  jumlahPenduduk Int?
  kategori       String?
  websiteUrl     String?
  dataStatus     DataStatus @default(DEMO)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  anggaranSummaries AnggaranDesaSummary[]
  apbdesItems       APBDesItem[]
  dokumenPublik     DokumenPublik[]
  dataSources       DataSource[]

  @@index([provinsi, kabupaten])
  @@index([dataStatus])
  @@map("desa")
}

model AnggaranDesaSummary {
  id                  String        @id @default(cuid())
  desaId              String
  tahun               Int
  totalAnggaran       Decimal       @db.Decimal(18, 2)
  totalRealisasi      Decimal       @db.Decimal(18, 2)
  persentaseRealisasi Int
  statusSerapan       StatusSerapan
  sumberData          String?
  dataStatus          DataStatus    @default(DEMO)
  sourceId            String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  desa   Desa        @relation(fields: [desaId], references: [id], onDelete: Cascade)
  source DataSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  @@unique([desaId, tahun])
  @@index([tahun, statusSerapan])
  @@index([dataStatus])
  @@map("anggaran_desa_summaries")
}

model APBDesItem {
  id         String     @id @default(cuid())
  desaId     String
  tahun      Int
  kodeBidang String?
  namaBidang String
  anggaran   Decimal    @db.Decimal(18, 2)
  realisasi  Decimal    @db.Decimal(18, 2)
  persentase Int
  dataStatus DataStatus @default(DEMO)
  sourceId   String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  desa   Desa        @relation(fields: [desaId], references: [id], onDelete: Cascade)
  source DataSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  @@index([desaId, tahun])
  @@index([dataStatus])
  @@map("apbdes_items")
}

model DokumenPublik {
  id           String         @id @default(cuid())
  desaId       String
  tahun        Int
  namaDokumen  String
  jenisDokumen String?
  status       DocumentStatus @default(UNKNOWN)
  url          String?
  dataStatus   DataStatus     @default(DEMO)
  sourceId     String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  desa   Desa        @relation(fields: [desaId], references: [id], onDelete: Cascade)
  source DataSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  @@index([desaId, tahun])
  @@index([status])
  @@index([dataStatus])
  @@map("dokumen_publik")
}

model DataSource {
  id            String     @id @default(cuid())
  desaId        String?
  sourceName    String
  sourceType    SourceType
  url           String?
  notes         String?
  lastCheckedAt DateTime?
  dataStatus    DataStatus @default(DEMO)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  desa              Desa?                  @relation(fields: [desaId], references: [id], onDelete: Cascade)
  anggaranSummaries AnggaranDesaSummary[]
  apbdesItems       APBDesItem[]
  dokumenPublik     DokumenPublik[]

  @@index([desaId])
  @@index([sourceType])
  @@index([dataStatus])
  @@map("data_sources")
}

enum DataStatus {
  DEMO
  IMPORTED
  NEEDS_REVIEW
  VERIFIED
  OUTDATED
  REJECTED
}

enum StatusSerapan {
  BAIK
  SEDANG
  RENDAH
}

enum DocumentStatus {
  TERSEDIA
  BELUM
  UNKNOWN
}

enum SourceType {
  DEMO
  MANUAL
  IMPORTED
  OFFICIAL
}

// ─── NextAuth v5 required tables ──────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
