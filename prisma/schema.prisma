// Claim lifecycle — state of the Admin Desa claim application
enum ClaimStatus {
  PENDING    // claim submitted, awaiting verification signal
  IN_REVIEW  // verification signal received, awaiting internal admin review
  REJECTED   // internal admin rejected with reason + instructions
  APPROVED   // internal admin approved — triggers membership VERIFIED
}

// Membership lifecycle — active access state of Admin Desa member
enum MemberStatus {
  LIMITED  // invite-only or verification-in-progress, restricted access
  VERIFIED // fully verified, one per desa
  REVOKED  // access removed, history preserved (no hard delete)
  EXPIRED  // verified access expired (e.g. renewal not completed)
}

enum ReasonCategory {
  WEBSITE_NOT_OFFICIAL
  WEBSITE_MISMATCH
  TOKEN_NOT_VALID
  EMAIL_NOT_CONVINCING
  DOCUMENT_NOT_SUFFICIENT
  SOURCE_CONFLICT
  SUSPICIOUS_ACTIVITY
  RENEWAL_FAILED
  OTHER
}

enum DocumentUploadStatus {
  WAITING_VERIFIED_APPROVAL // uploaded by LIMITED, waiting for VERIFIED approval
  PROCESSING                // in internal admin review / AI mapping queue
  PUBLISHED                 // approved, mapped, published
  FAILED                    // rejected with user-safe reason
}

enum AdminClaimMethod {
  OFFICIAL_EMAIL
  WEBSITE_TOKEN
  SUPPORT_REVIEW
  INVITE
}

enum DesaAdminRole {
  LIMITED_ADMIN
  VERIFIED_ADMIN
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum ReportStatus {
  OPEN
  REVIEWING
  RESOLVED
  REJECTED
}

// ─── NextAuth v5 required tables ──────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
