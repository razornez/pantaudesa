generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  // NextAuth required fields — must match exact names PrismaAdapter expects
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  // PantauDesa custom fields
  username       String?   @unique
  nama           String?
  bio            String?
  avatarUrl      String?
  role           Role      @default(WARGA)
  // PIN auth
  pinHash        String?
  pinAttempts    Int       @default(0)
  pinLockedUntil DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // NextAuth relations
  accounts Account[]
  sessions Session[]

  // Citizen voice relations
  voices     Voice[]
  replies    VoiceReply[]
  votes      VoiceVote[]
  helpfuls   VoiceHelpful[]

  @@map("users")
}

// ─── OTP ──────────────────────────────────────────────────────────────────────

model OtpCode {
  id        String     @id @default(cuid())
  email     String
  codeHash  String
  purpose   OtpPurpose
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime   @default(now())

  @@index([email, purpose])
  @@map("otp_codes")
}

enum OtpPurpose {
  REGISTER
  RESET_PIN
  UNFREEZE
}

// ─── Citizen Voice ────────────────────────────────────────────────────────────

model Voice {
  id         String        @id @default(cuid())
  desaId     String
  category   VoiceCategory
  text       String        @db.Text
  isAnon     Boolean       @default(false)
  status     VoiceStatus   @default(OPEN)
  resolvedAt DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  authorId   String?
  author     User?         @relation(fields: [authorId], references: [id], onDelete: SetNull)

  replies    VoiceReply[]
  votes      VoiceVote[]
  helpfuls   VoiceHelpful[]

  @@index([desaId])
  @@index([createdAt])
  @@map("voices")
}

model VoiceReply {
  id              String   @id @default(cuid())
  voiceId         String
  text            String   @db.Text
  isAnon          Boolean  @default(false)
  isOfficialDesa  Boolean  @default(false)
  createdAt       DateTime @default(now())

  authorId  String?
  author    User?   @relation(fields: [authorId], references: [id], onDelete: SetNull)
  voice     Voice   @relation(fields: [voiceId], references: [id], onDelete: Cascade)

  @@index([voiceId])
  @@map("voice_replies")
}

model VoiceVote {
  id        String    @id @default(cuid())
  voiceId   String
  userId    String
  type      VoteType
  createdAt DateTime  @default(now())

  voice  Voice @relation(fields: [voiceId], references: [id], onDelete: Cascade)
  user   User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([voiceId, userId])
  @@map("voice_votes")
}

model VoiceHelpful {
  id        String   @id @default(cuid())
  voiceId   String
  userId    String
  createdAt DateTime @default(now())

  voice  Voice @relation(fields: [voiceId], references: [id], onDelete: Cascade)
  user   User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([voiceId, userId])
  @@map("voice_helpfuls")
}

enum VoiceCategory {
  infrastruktur
  bansos
  fasilitas
  anggaran
  lingkungan
  lainnya
}

enum VoiceStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum VoteType {
  BENAR
  BOHONG
}

enum Role {
  WARGA
  DESA
  ADMIN
}

// ─── Sprint 03 Data Foundation ────────────────────────────────────────────────

model Desa {
  id              String                 @id @default(cuid())
  kodeDesa        String?                @unique
  nama            String
  slug            String                 @unique
  kecamatan       String
  kabupaten       String
  provinsi        String
  tahunData       Int?
  jumlahPenduduk  Int?
  kategori        String?
  websiteUrl      String?
  dataStatus      DataStatus             @default(demo)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  dataSources       DataSource[]
  anggaranSummaries AnggaranDesaSummary[]
  apbdesItems       APBDesItem[]
  dokumenPublik     DokumenPublik[]

  @@index([kecamatan, kabupaten, provinsi])
  @@index([dataStatus])
  @@map("desa")
}

model DataSource {
  id               String           @id @default(cuid())
  desaId           String?
  scopeType        ScopeType
  scopeName        String
  sourceName       String
  sourceUrl        String?
  sourceType       SourceType
  accessStatus     AccessStatus     @default(unknown)
  dataAvailability DataAvailability @default(unknown)
  lastCheckedAt    DateTime?
  notes            String?          @db.Text
  dataStatus       DataStatus       @default(needs_review)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  desa              Desa?                  @relation(fields: [desaId], references: [id], onDelete: SetNull)
  anggaranSummaries AnggaranDesaSummary[]
  apbdesItems       APBDesItem[]
  dokumenPublik     DokumenPublik[]

  @@index([desaId])
  @@index([scopeType, scopeName])
  @@index([sourceType])
  @@index([accessStatus])
  @@index([dataStatus])
  @@map("data_sources")
}

model AnggaranDesaSummary {
  id                    String        @id @default(cuid())
  desaId                String
  tahun                 Int
  totalAnggaran         BigInt?
  totalRealisasi        BigInt?
  persentaseRealisasi   Decimal?      @db.Decimal(5, 2)
  statusSerapan         StatusSerapan @default(unknown)
  sourceId              String?
  dataStatus            DataStatus    @default(demo)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  desa   Desa        @relation(fields: [desaId], references: [id], onDelete: Cascade)
  source DataSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  @@unique([desaId, tahun])
  @@index([tahun])
  @@index([sourceId])
  @@index([dataStatus])
  @@map("anggaran_desa_summaries")
}

model APBDesItem {
  id          String     @id @default(cuid())
  desaId      String
  tahun       Int
  kodeBidang  String?
  namaBidang  String
  anggaran    BigInt?
  realisasi   BigInt?
  persentase  Decimal?   @db.Decimal(5, 2)
  sourceId    String?
  dataStatus  DataStatus @default(demo)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  desa   Desa        @relation(fields: [desaId], references: [id], onDelete: Cascade)
  source DataSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  @@index([desaId, tahun])
  @@index([sourceId])
  @@index([dataStatus])
  @@map("apbdes_items")
}

model DokumenPublik {
  id             String         @id @default(cuid())
  desaId         String
  tahun          Int?
  namaDokumen    String
  jenisDokumen   DocumentType   @default(other)
  status         DocumentStatus @default(unknown)
  url            String?
  fileType       String?
  sourceId       String?
  publishedAt    DateTime?
  lastCheckedAt  DateTime?
  dataStatus     DataStatus     @default(demo)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  desa   Desa        @relation(fields: [desaId], references: [id], onDelete: Cascade)
  source DataSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  @@index([desaId, tahun])
  @@index([jenisDokumen])
  @@index([status])
  @@index([sourceId])
  @@index([dataStatus])
  @@map("dokumen_publik")
}

enum DataStatus {
  demo
  imported
  needs_review
  verified
  outdated
  rejected
}

enum SourceType {
  demo
  manual
  official_website
  official_document
  kecamatan_page
  article_page
  archive_page
  other
}

enum ScopeType {
  desa
  kecamatan
  kabupaten
  provinsi
  national
  other
}

enum AccessStatus {
  accessible
  unreachable
  broken
  unknown
  requires_review
}

enum DataAvailability {
  none
  profile_only
  documents_only
  budget_summary
  budget_detail
  mixed
  unknown
}

enum StatusSerapan {
  baik
  sedang
  rendah
  unknown
}

enum DocumentStatus {
  tersedia
  belum
  unknown
  needs_review
}

enum DocumentType {
  apbdes
  realisasi
  rkpdes
  rpjmdes
  perdes
  lppd
  profile
  other
}

// ─── NextAuth v5 required tables ──────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
