generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String?  @unique   // filled on /daftar after first login
  nama      String?            // filled on /daftar after first login
  bio       String?
  avatarUrl String?
  role      Role     @default(WARGA)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // NextAuth relations
  accounts Account[]
  sessions Session[]

  // Citizen voice relations
  voices     Voice[]
  replies    VoiceReply[]
  votes      VoiceVote[]
  helpfuls   VoiceHelpful[]

  @@map("users")
}

// ─── Citizen Voice ────────────────────────────────────────────────────────────

model Voice {
  id         String        @id @default(cuid())
  desaId     String
  category   VoiceCategory
  text       String        @db.Text
  isAnon     Boolean       @default(false)
  status     VoiceStatus   @default(OPEN)
  resolvedAt DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  authorId   String?
  author     User?         @relation(fields: [authorId], references: [id], onDelete: SetNull)

  replies    VoiceReply[]
  votes      VoiceVote[]
  helpfuls   VoiceHelpful[]

  @@index([desaId])
  @@index([createdAt])
  @@map("voices")
}

model VoiceReply {
  id              String   @id @default(cuid())
  voiceId         String
  text            String   @db.Text
  isAnon          Boolean  @default(false)
  isOfficialDesa  Boolean  @default(false)
  createdAt       DateTime @default(now())

  authorId  String?
  author    User?   @relation(fields: [authorId], references: [id], onDelete: SetNull)
  voice     Voice   @relation(fields: [voiceId], references: [id], onDelete: Cascade)

  @@index([voiceId])
  @@map("voice_replies")
}

model VoiceVote {
  id        String    @id @default(cuid())
  voiceId   String
  userId    String
  type      VoteType
  createdAt DateTime  @default(now())

  voice  Voice @relation(fields: [voiceId], references: [id], onDelete: Cascade)
  user   User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([voiceId, userId])
  @@map("voice_votes")
}

model VoiceHelpful {
  id        String   @id @default(cuid())
  voiceId   String
  userId    String
  createdAt DateTime @default(now())

  voice  Voice @relation(fields: [voiceId], references: [id], onDelete: Cascade)
  user   User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([voiceId, userId])
  @@map("voice_helpfuls")
}

enum VoiceCategory {
  infrastruktur
  bansos
  fasilitas
  anggaran
  lingkungan
  lainnya
}

enum VoiceStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum VoteType {
  BENAR
  BOHONG
}

enum Role {
  WARGA
  DESA
  ADMIN
}

// ─── NextAuth v5 required tables ──────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
